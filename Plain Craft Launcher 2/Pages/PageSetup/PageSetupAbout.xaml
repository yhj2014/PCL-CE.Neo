<local:MyPageRight
    x:Class="PageSetupAbout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:app="clr-namespace:PCL.Core.App;assembly=PCL.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PCL"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    DataContext="{Binding Source={x:Static app:Basics.Metadata}}"
    PanScroll="{Binding ElementName=PanBack}"
    RenderOptions.BitmapScalingMode="LowQuality">
    <local:MyScrollViewer
        x:Name="PanBack"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            x:Name="PanMain"
            Margin="25,10"
            Grid.IsSharedSizeScope="True">
            <local:MyCard Margin="0,15" Title="关于">
                <Grid Margin="21,40,21,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <local:MyListItem
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="-5,0,15,0"
                        Info="Plain Craft Launcher 的原作者！"
                        IsHitTestVisible="False"
                        Title="龙腾猫跃" />
                    <local:MyListItem
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="-5,0,15,0"
                        Info="Plain Craft Launcher 社区版的开发团队！"
                        IsHitTestVisible="False"
                        Title="PCL Community" />
                    <local:MyListItem
                        x:Name="ItemAboutPcl"
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="-5,0,15,0"
                        Info="当前版本: %VERSION% (%BRANCH%, %VERSIONCODE%, %COMMIT_HASH%)"
                        IsHitTestVisible="False"
                        Title="{Binding Name}" />
                    <Image
                        x:Name="ImgPCLLogo"
                        Grid.Row="2"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/Logo-CE.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="0"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/LTCat.jpg">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        x:Name="ImgPCLCommunity"
                        Grid.Row="1"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/PCL-Community.png" />
                    <local:MyButton
                        Grid.Row="0"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://afdian.com/a/LTCat"
                        local:CustomEventService.EventType="打开网页"
                        Text="赞助原作者" />
                    <local:MyButton
                        Grid.Row="1"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://github.com/PCL-Community"
                        local:CustomEventService.EventType="打开网页"
                        Text="GitHub 主页" />
                    <local:MyButton
                        Grid.Row="2"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://github.com/PCL-Community/PCL2-CE"
                        local:CustomEventService.EventType="打开网页"
                        Text="查看源代码" />
                </Grid>
            </local:MyCard>
            <local:MyCard Margin="0,0,0,15" Title="特别鸣谢">
                <Grid Margin="21,40,21,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                        <RowDefinition Height="45" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <local:MyListItem
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="-5,0,15,0"
                        Info="提供 BMCLAPI 镜像源和 Forge 安装工具，详见 https://bmclapi.bangbang93.com"
                        IsHitTestVisible="False"
                        Title="bangbang93" />
                    <local:MyButton
                        Grid.Row="0"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://afdian.com/a/bangbang93"
                        local:CustomEventService.EventType="打开网页"
                        Text="赞助镜像源" />
                    <local:MyListItem
                        Grid.Row="1"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了 Mod 名称的中文翻译和更多相关信息！"
                        IsHitTestVisible="False"
                        Title="MC 百科" />
                    <local:MyButton
                        Grid.Row="1"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://www.mcmod.cn"
                        local:CustomEventService.EventType="打开网页"
                        Text="打开百科" />
                    <local:MyListItem
                        Grid.Row="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了 PCL CE 的相关云服务"
                        IsHitTestVisible="False"
                        Title="Pysio @ Akaere Network" />
                    <local:MyButton
                        Grid.Row="2"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://www.pysio.online"
                        local:CustomEventService.EventType="打开网页"
                        Text="转到博客" />
                    <local:MyListItem
                        Grid.Row="3"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了 PCL CE 的相关云服务"
                        IsHitTestVisible="False"
                        Title="云默安 @ 至远光辉" />
                    <local:MyButton
                        Grid.Row="3"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://www.zyghit.cn"
                        local:CustomEventService.EventType="打开网页"
                        Text="打开网站" />
                    <local:MyListItem
                        Grid.Row="4"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了联机模块"
                        IsHitTestVisible="False"
                        Title="EasyTier" />
                    <local:MyButton
                        Grid.Row="4"
                        Grid.Column="2"
                        Height="35"
                        local:CustomEventService.EventData="https://easytier.cn"
                        local:CustomEventService.EventType="打开网页"
                        Text="打开网站" />
                    <local:MyListItem
                        Grid.Row="5"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了 MCIM 中国 Mod 下载镜像源和帮助库图床！"
                        IsHitTestVisible="False"
                        Title="z0z0r4" />
                    <local:MyListItem
                        Grid.Row="6"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="提供了 Java Launch Wrapper 和一些重要服务支持！"
                        IsHitTestVisible="False"
                        Title="00ll00" />
                    <local:MyListItem
                        Grid.Row="7"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="设计并制作了 PCL 图标，让龙猫从做图标的水深火热中得到了解脱……"
                        IsHitTestVisible="False"
                        Title="Patrick" />
                    <local:MyListItem
                        Grid.Row="8"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="在 PCL 内测中找出了一大堆没人想得到的诡异 Bug，有非同寻常的 Bug 体质"
                        IsHitTestVisible="False"
                        Title="Hao_Tian" />
                    <local:MyListItem
                        Grid.Row="9"
                        Grid.Column="1"
                        Margin="-5,0,15,0"
                        Info="虽然已经关站了，但感谢此前提供了 MCBBS 镜像源……"
                        IsHitTestVisible="False"
                        Title="Minecraft 中文论坛" />
                    <local:MyListItem
                        Grid.Row="10"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Margin="-5,0,0,0"
                        Info="感谢内群的沙雕网友们这么久以来对龙猫和 PCL 的支持与鼓励！"
                        IsHitTestVisible="False"
                        Title="PCL 内群的各位" />
                    <Image
                        Grid.Row="0"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/bangbang93.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="1"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/wiki.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="2"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/Pysio.jpg">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="3"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/Yunmoan.jpg">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="4"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/EasyTier.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="5"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/z0z0r4.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="6"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/00ll00.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="7"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/Patrick.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="8"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/Hao_Tian.jpg">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="9"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/MCBBS.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                    <Image
                        Grid.Row="10"
                        Margin="3"
                        Source="/Plain Craft Launcher 2;component/Images/Heads/PCL2.png">
                        <Image.Clip>
                            <EllipseGeometry
                                Center="17 17"
                                RadiusX="17"
                                RadiusY="17" />
                        </Image.Clip>
                    </Image>
                </Grid>
            </local:MyCard>
            <local:MyCard
                Margin="0,0,0,15"
                DataContext="{Binding RelativeSource={RelativeSource AncestorType=local:PageSetupAbout}}"
                Title="贡献者们">
                <Grid Margin="17,42,15,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ItemsControl ItemsSource="{Binding Contributors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel
                                    Width="72"
                                    Margin="4,8"
                                    HorizontalAlignment="Center"
                                    Orientation="Vertical">
                                    <local:MyImage
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding AvatarUrl}" />
                                    <local:MyTextButton
                                        MaxWidth="90"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        local:CustomEventService.EventData="{Binding HtmlUrl}"
                                        local:CustomEventService.EventType="打开网页"
                                        Text="{Binding Login}"
                                        ToolTip="{Binding Login}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <local:MyTextButton
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        local:CustomEventService.EventData="https://github.com/PCL-Community/PCL2-CE/graphs/contributors"
                        local:CustomEventService.EventType="打开网页"
                        Text="查看更多" />
                </Grid>
            </local:MyCard>

            <local:MyCard
                Margin="0,0,0,15"
                CanSwap="True"
                Title="版权声明与法律信息">
                <StackPanel Margin="25,39,23,20">
                    <TextBlock
                        Margin="0,6,0,4"
                        FontWeight="Bold"
                        Text="隐私说明"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,0,0,2"
                        LineHeight="17"
                        Text="本软件的 User Agent 中包含启动器的版本号，以统计各版本的用户数量。&#13;除此之外，本软件不会向开发者上传任何其他信息。&#13;* 联机与软硬件调查相关功能遵循其自身的隐私政策，与上述说明不通用。"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,12,0,4"
                        FontWeight="Bold"
                        Text="其他信息"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,0,0,2"
                        LineHeight="17"
                        Text="Copyright © 2026 PCL Community &#x26; 龙腾猫跃.&#13;非 MINECRAFT 官方产品。未经 MOJANG 或 MICROSOFT 批准，也不与 MOJANG 或 MICROSOFT 关联。"
                        TextWrapping="Wrap" />
                    <StackPanel
                        Height="35"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <local:MyButton
                            Margin="0,0,20,0"
                            ColorType="Highlight"
                            local:CustomEventService.EventData="https://github.com/PCL-Community/PCL2-CE"
                            local:CustomEventService.EventType="打开网页"
                            Padding="13,0"
                            Text="社区版开源代码" />
                        <local:MyButton
                            Margin="0,0,20,0"
                            local:CustomEventService.EventData="https://www.pclc.cc/privacy/personal-info-brief.html"
                            local:CustomEventService.EventType="打开网页"
                            Padding="13,0"
                            Text="社区版联机大厅隐私政策" />
                        <local:MyButton
                            Margin="0,0,20,0"
                            local:CustomEventService.EventData="https://account.naids.com/policy"
                            local:CustomEventService.EventType="打开网页"
                            Padding="13,0"
                            Text="Natayark OpenID 服务条款" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>
            <local:MyCard
                Margin="0,0,0,15"
                CanSwap="True"
                IsSwapped="True"
                Title="上游版权与法律信息">
                <StackPanel Margin="25,39,23,20">
                    <TextBlock
                        Margin="0,6,0,4"
                        FontWeight="Bold"
                        Text="隐私说明"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,0,0,2"
                        LineHeight="17"
                        Text="本软件的 User Agent 中包含启动器的版本号，以统计各版本的用户数量。&#13;除此之外，本软件不会向开发者上传任何其他信息。"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,12,0,4"
                        FontWeight="Bold"
                        Text="其他信息"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,0,0,2"
                        LineHeight="17"
                        Text="Copyright © 龙腾猫跃 2016. All Rights Reserved.&#13;计算机软件著作权登记号：2020SR0875133&#13;违法违规行为举报投诉邮箱：hexdragon@vip.qq.com&#13;非 MINECRAFT 官方产品。未经 MOJANG 或 MICROSOFT 批准，也不与 MOJANG 或 MICROSOFT 关联。"
                        TextWrapping="Wrap" />
                    <StackPanel
                        Height="35"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal">
                        <local:MyButton
                            Width="160"
                            Margin="0,0,20,0"
                            ColorType="Highlight"
                            local:CustomEventService.EventData="https://shimo.im/docs/rGrd8pY8xWkt6ryW"
                            local:CustomEventService.EventType="打开网页"
                            Padding="13,0"
                            Text="用户协议与免责声明" />
                        <local:MyButton
                            Width="120"
                            Margin="0,0,20,0"
                            local:CustomEventService.EventData="https://github.com/Meloong-Git/PCL"
                            local:CustomEventService.EventType="打开网页"
                            Padding="13,0"
                            Text="开源代码" />
                    </StackPanel>
                </StackPanel>
            </local:MyCard>
            <local:MyCard
                Margin="0,0,0,15"
                CanSwap="True"
                IsSwapped="True"
                Title="许可与版权声明">
                <ItemsControl Margin="25,42,23,4" ItemsSource="{Binding Licenses}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LicenseName" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="60" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    FontWeight="Bold"
                                    Text="{Binding Name}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Text="{Binding Information}"
                                    TextWrapping="Wrap" />
                                <local:MyButton
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    MinWidth="140"
                                    Margin="0,7,20,18"
                                    HorizontalAlignment="Left"
                                    local:CustomEventService.EventData="{Binding WebsiteUri}"
                                    local:CustomEventService.EventType="打开网页"
                                    Padding="13,0"
                                    Text="查看来源网站"
                                    Visibility="{Binding WebsiteUri, Converter={StaticResource NullToVisibilityConverter}}" />
                                <local:MyButton
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    MinWidth="140"
                                    Margin="0,7,20,18"
                                    HorizontalAlignment="Left"
                                    local:CustomEventService.EventData="{Binding LicenseUri}"
                                    local:CustomEventService.EventType="打开网页"
                                    Padding="13,0"
                                    Text="查看许可文档"
                                    Visibility="{Binding LicenseUri, Converter={StaticResource NullToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>