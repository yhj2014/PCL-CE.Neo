<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <AssemblyTitle>PCL-CE.Neo.App.Windows</AssemblyTitle>
        <AssemblyName>PCL-CE.Neo.App.Windows</AssemblyName>
        <Description>PCL CE Neo Windows 应用入口</Description>
        <Company>PCL Community</Company>
        <Product>PCL-CE.Neo.App.Windows</Product>
        <Copyright>Copyright © PCL Community</Copyright>
        <AssemblyVersion>1.0.0.0</AssemblyVersion>
        <FileVersion>1.0.0.0</FileVersion>
        <OutputType>WinExe</OutputType>
        <RootNamespace>PCL_CE.Neo.App</RootNamespace>
        <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
        <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
        <UseWinUI>true</UseWinUI>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <SelfContained>true</SelfContained>
        <PublishSingleFile>false</PublishSingleFile>
        <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <ApplicationDefinition Include="App.xaml" />
        <Page Include="**\*.xaml" />
        <Compile Include="**\*.cs" Exclude="bin\**;obj\**" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Uno.WinUI" Version="5.0.0" />
        <PackageReference Include="Uno.Toolkit.WinUI" Version="5.0.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\PCL-CE.Neo.UI\PCL-CE.Neo.UI.csproj" />
        <ProjectReference Include="..\PCL-CE.Neo.Platform.Windows\PCL-CE.Neo.Platform.Windows.csproj" />
    </ItemGroup>

</Project>
