<Window
    x:Class="PCL_CE.Neo.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid Background="{StaticResource BackgroundBrush}" Padding="24">
        <StackPanel Spacing="20">
            <TextBlock Text="PCL CE Neo" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
            
            <TextBlock Text="跨平台 Minecraft 启动器" 
                       FontSize="16" 
                       Foreground="#CCCCCC"/>
            
            <TextBlock Text="当前版本：v0.0.1-alpha (开发版)" 
                       FontSize="14" 
                       Foreground="#888888"/>
            
            <Border Background="#2D2D30" Padding="20" CornerRadius="8" Margin="0,20,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="功能预览" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="🎯 跨平台支持 (Windows/macOS/Linux)" Foreground="#DDDDDD"/>
                    <TextBlock Text="🎮 完整的游戏启动功能" Foreground="#DDDDDD"/>
                    <TextBlock Text="📦 游戏版本下载与管理" Foreground="#DDDDDD"/>
                    <TextBlock Text="💾 多实例管理" Foreground="#DDDDDD"/>
                    <TextBlock Text="🎨 深色/浅色主题切换" Foreground="#DDDDDD"/>
                </StackPanel>
            </Border>
            
            <TextBlock x:Name="StatusText" 
                       Text="✅ 核心架构已就绪" 
                       FontSize="14" 
                       Foreground="#50C878" 
                       Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>
