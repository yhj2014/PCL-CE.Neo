                <ResourceDictionary Source="pack://application:,,,/PCL-CE.Neo.UI;component/Resources/Dimensions.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PCL-CE.Neo.UI;component/Resources/TextStyles.xaml" />
