<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <AssemblyTitle>PCL-CE.Neo.App.Linux</AssemblyTitle>
        <AssemblyName>PCL-CE.Neo.App.Linux</AssemblyName>
        <Description>PCL CE Neo Linux 应用入口</Description>
        <Company>PCL Community</Company>
        <Product>PCL-CE.Neo.App.Linux</Product>
        <Copyright>Copyright © PCL Community</Copyright>
        <AssemblyVersion>1.0.0.0</AssemblyVersion>
        <FileVersion>1.0.0.0</FileVersion>
        <OutputType>Exe</OutputType>
        <RootNamespace>PCL_CE.Neo.App</RootNamespace>
        <TargetFramework>net10.0-linux</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
        <SelfContained>true</SelfContained>
        <PublishSingleFile>false</PublishSingleFile>
        <DefineConstants>$(DefineConstants);LINUX</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <ApplicationDefinition Include="App.xaml" />
        <Page Include="**\*.xaml" />
        <Compile Include="**\*.cs" Exclude="bin\**;obj\**" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Uno.WinUI" Version="5.0.0" />
        <PackageReference Include="Uno.Toolkit.WinUI" Version="5.0.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\PCL-CE.Neo.UI\PCL-CE.Neo.UI.csproj" />
        <ProjectReference Include="..\PCL-CE.Neo.Platform.Linux\PCL-CE.Neo.Platform.Linux.csproj" />
    </ItemGroup>

</Project>
