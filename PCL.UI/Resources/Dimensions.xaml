<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Button Dimensions -->
    <sys:Double x:Key="ButtonMinWidth">80</sys:Double>
    <sys:Double x:Key="ButtonMinHeight">32</sys:Double>
    <Thickness x:Key="ButtonPadding">12,6</Thickness>
    <CornerRadius x:Key="ButtonCornerRadius">4</CornerRadius>

    <!-- Control Dimensions -->
    <sys:Double x:Key="IconSize">24</sys:Double>
    <sys:Double x:Key="SmallIconSize">16</sys:Double>
    <sys:Double x:Key="LargeIconSize">32</sys:Double>

    <!-- Spacing -->
    <Thickness x:Key="DefaultMargin">8</Thickness>
    <Thickness x:Key="SmallMargin">4</Thickness>
    <Thickness x:Key="LargeMargin">16</Thickness>
    <Thickness x:Key="ExtraLargeMargin">24</Thickness>

    <!-- Card Dimensions -->
    <sys:Double x:Key="CardMinHeight">100</sys:Double>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>

    <!-- Border Dimensions -->
    <sys:Double x:Key="BorderWidth">1</sys:Double>
    <CornerRadius x:Key="BorderCornerRadius">4</CornerRadius>

    <!-- Input Control Dimensions -->
    <sys:Double x:Key="InputMinWidth">120</sys:Double>
    <sys:Double x:Key="InputMinHeight">32</sys:Double>

    <!-- ScrollViewer Dimensions -->
    <sys:Double x:Key="ScrollBarWidth">12</sys:Double>

</ResourceDictionary>
