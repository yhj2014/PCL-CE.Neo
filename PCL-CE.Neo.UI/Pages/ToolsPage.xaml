<Page
    x:Class="PCL_CE.Neo.UI.Pages.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PCL_CE.Neo.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondaryBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource IconButtonStyle}"
                        Click="OnBackClick">
                    <TextBlock Text="←"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="工具箱"
                           Style="{StaticResource TitleStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16">
            <StackPanel Spacing="16">
                <controls:Card>
                    <StackPanel Spacing="12">
                        <TextBlock Text="游戏工具"
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnForgeInstallerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="🔧"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Forge 安装器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="为游戏安装 Forge mod loader"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnFabricInstallerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="🧵"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Fabric 安装器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="为游戏安装 Fabric mod loader"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnOptiFineInstallerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="⚡"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="OptiFine 安装器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="安装性能优化 mod"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </controls:Card>

                <controls:Card>
                    <StackPanel Spacing="12">
                        <TextBlock Text="系统工具"
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnJavaCheckerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="☕"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Java 检测器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="检测并管理系统中的 Java 版本"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnCacheCleanerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="🧹"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="缓存清理器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="清理游戏缓存和临时文件"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnBackupManagerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="💾"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="备份管理器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="管理和恢复游戏存档"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </controls:Card>

                <controls:Card>
                    <StackPanel Spacing="12">
                        <TextBlock Text="诊断工具"
                                   Style="{StaticResource TitleStyle}"/>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnNetworkDiagnosticsClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="🌐"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="网络诊断"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="测试网络连接和下载速度"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BackgroundTertiaryBrush}"
                                CornerRadius="8"
                                Padding="16"
                                Tapped="OnLogViewerClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="📋"
                                           FontSize="32"
                                           VerticalAlignment="Center"
                                           Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="日志查看器"
                                               Style="{StaticResource TitleStyle}"/>
                                    <TextBlock Text="查看和分析游戏日志"
                                               Style="{StaticResource CaptionStyle}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="→"
                                           FontSize="20"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </controls:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
