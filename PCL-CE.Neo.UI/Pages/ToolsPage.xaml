<Page
    x:Class="PCL_CE.Neo.UI.Pages.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="工具箱" Style="{StaticResource H1Style}"/>
        <TextBlock Text="实用工具和辅助功能" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="游戏管理" Style="{StaticResource H2Style}"/>
                <Button Content="打开游戏目录" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Content="备份存档" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Content="导出崩溃报告" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="网络诊断" Style="{StaticResource H2Style}"/>
                <Button Content="测试网络连接" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Content="检查 DNS 解析" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Content="下载速度测试" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="Java 管理" Style="{StaticResource H2Style}"/>
                <Button Content="检测已安装的 Java" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
                <Button Content="下载推荐 Java" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
