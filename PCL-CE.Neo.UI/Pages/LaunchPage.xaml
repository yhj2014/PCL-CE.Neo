<Page
    x:Class="PCL_CE.Neo.UI.Pages.LaunchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="启动游戏" Style="{StaticResource H1Style}"/>
        <TextBlock Text="选择要启动的游戏实例和版本" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="当前配置" Style="{StaticResource H2Style}"/>
                <TextBlock Text="版本: 1.21.1" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="账号: 未登录" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="Java: 自动检测" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="启动设置" Style="{StaticResource H2Style}"/>
                <TextBlock Text="内存分配: 2 GB - 8 GB (自动)" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="游戏目录: .minecraft" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="Java 路径: 自动检测" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="启动游戏" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="测试启动" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Page>
