<Page
    x:Class="PCL_CE.Neo.UI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="欢迎使用 PCL CE Neo" Style="{StaticResource H1Style}"/>
        <TextBlock Text="现代化、跨平台的 Minecraft 启动器" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="快速开始" Style="{StaticResource H2Style}"/>
                <TextBlock Text="• 点击左侧「启动游戏」启动 Minecraft" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="• 点击「版本下载」下载 Minecraft 版本" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="• 点击「账号登录」配置你的 Microsoft 账号" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="系统信息" Style="{StaticResource H2Style}"/>
                <TextBlock Text="版本: 0.0.1-alpha" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="框架: .NET 10 + Uno Platform" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="目标平台: Windows / Linux / macOS" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
