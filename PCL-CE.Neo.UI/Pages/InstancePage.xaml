<Page
    x:Class="PCL_CE.Neo.UI.Pages.InstancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="实例管理" Style="{StaticResource H1Style}"/>
        <TextBlock Text="管理你的游戏实例和 Mod" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="默认实例 (.minecraft)" Style="{StaticResource H2Style}"/>
                <TextBlock Text="版本: 1.21.1" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="Mod 数量: 0" Style="{StaticResource BodyStyle}"/>
                <TextBlock Text="存档数: 0" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="新建实例" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="导入实例" Style="{StaticResource SecondaryButtonStyle}"/>
            <Button Content="导出实例" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Page>
