<Page
    x:Class="PCL_CE.Neo.UI.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="版本下载" Style="{StaticResource H1Style}"/>
        <TextBlock Text="选择一个 Minecraft 版本进行下载" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="最新正式版" Style="{StaticResource H2Style}"/>
                <TextBlock Text="Minecraft 1.21.1" Style="{StaticResource BodyStyle}"/>
                <Button Content="下载" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="最新快照" Style="{StaticResource H2Style}"/>
                <TextBlock Text="24w33a" Style="{StaticResource BodyStyle}"/>
                <Button Content="下载" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="历史版本" Style="{StaticResource H2Style}"/>
                <TextBlock Text="1.20.4, 1.19.4, 1.18.2, 1.17.1, 1.16.5, 1.15.2, 1.14.4, 1.13.2, 1.12.2, 1.11.2, 1.10.2, 1.9.4, 1.8.9" Style="{StaticResource BodyStyle}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
