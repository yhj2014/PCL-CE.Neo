<Page
    x:Class="PCL_CE.Neo.UI.Pages.DownloadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PCL_CE.Neo.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondaryBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource IconButtonStyle}"
                        Click="OnBackClick">
                    <TextBlock Text="←"/>
                </Button>

                <TextBlock Grid.Column="1"
                           x:Name="PageTitle"
                           Text="下载管理"
                           Style="{StaticResource TitleStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <controls:MyIconButton Grid.Column="2"
                                      Icon="📁"
                                      Tooltip="打开文件夹"
                                      Click="OnOpenFolderClick"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:Card Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="当前下载任务"
                               Style="{StaticResource TitleStyle}"/>
                    <ProgressBar x:Name="DownloadProgress"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource BackgroundTertiaryBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DownloadStatusText"
                                   Grid.Column="0"
                                   Text="准备就绪"
                                   Style="{StaticResource BodyStyle}"/>
                        <TextBlock x:Name="DownloadPercentText"
                                   Grid.Column="1"
                                   Text="0%"
                                   Style="{StaticResource BodySecondaryStyle}"/>
                    </Grid>
                </StackPanel>
            </controls:Card>

            <TextBlock Grid.Row="1"
                       Text="下载队列"
                       Style="{StaticResource SubheadingStyle}"
                       Margin="0,0,0,8"/>

            <ScrollViewer Grid.Row="2">
                <ItemsControl x:Name="DownloadQueue">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundSecondaryBrush}"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="48"
                                            Height="48"
                                            Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="8"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="📦"
                                                   FontSize="24"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource TitleStyle}"/>
                                        <TextBlock Text="{Binding Status}"
                                                   Style="{StaticResource CaptionStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Click="OnPauseResumeClick"
                                                Tag="{Binding}">
                                            <TextBlock Text="⏸️"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Click="OnCancelClick"
                                                Tag="{Binding}">
                                            <TextBlock Text="❌"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <controls:MyButton Text="清空已完成"
                                  Margin="0,0,8,0"
                                  Click="OnClearCompletedClick"/>
                <controls:MyButton Text="开始全部"
                                  Click="OnStartAllClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
