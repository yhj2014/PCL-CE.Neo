<Page
    x:Class="PCL_CE.Neo.UI.Pages.VersionSelectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PCL_CE.Neo.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondaryBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource IconButtonStyle}"
                        Click="OnBackClick">
                    <TextBlock Text="←"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="选择游戏版本"
                           Style="{StaticResource TitleStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <controls:MyIconButton Grid.Column="2"
                                      Icon="🔄"
                                      Tooltip="刷新"
                                      Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:MyTextBox Grid.Row="0"
                               Placeholder="搜索版本..."
                               Margin="0,0,0,16"
                               TextChanged="OnSearchTextChanged"/>

            <ScrollViewer Grid.Row="1">
                <ItemsControl x:Name="VersionList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BackgroundSecondaryBrush}"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8"
                                    Tapped="OnVersionTapped">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource TitleStyle}"/>
                                        <TextBlock Text="{Binding Version}"
                                                   Style="{StaticResource BodySecondaryStyle}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource CaptionStyle}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="→"
                                               FontSize="20"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
