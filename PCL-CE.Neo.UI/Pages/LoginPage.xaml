<Page
    x:Class="PCL_CE.Neo.UI.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="16">
        <TextBlock Text="账号登录" Style="{StaticResource H1Style}"/>
        <TextBlock Text="登录你的 Microsoft 账号以进入游戏" Style="{StaticResource BodyStyle}"/>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="当前账号" Style="{StaticResource H2Style}"/>
                <TextBlock Text="未登录" Style="{StaticResource BodyStyle}"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel Spacing="12">
                <TextBlock Text="离线登录" Style="{StaticResource H2Style}"/>
                <TextBox PlaceholderText="玩家名" Style="{StaticResource BaseTextBoxStyle}" Width="280"/>
                <Button Content="以离线模式开始" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Microsoft 登录" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="刷新状态" Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </StackPanel>
</Page>
