<Page
    x:Class="PCL_CE.Neo.UI.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PCL_CE.Neo.UI.Controls"
    mc:Ignorable="d">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BackgroundSecondaryBrush}"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource IconButtonStyle}"
                        Click="OnBackClick">
                    <TextBlock Text="←"/>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="账号登录"
                           Style="{StaticResource TitleStyle}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="32" Spacing="24" HorizontalAlignment="Center" MaxWidth="400">
                <!-- Logo and Title -->
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <Border Width="96" Height="96"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="16">
                        <TextBlock Text="🎮" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PCL CE Neo" Style="{StaticResource HeadingStyle}" TextAlignment="Center"/>
                    <TextBlock Text="跨平台 Minecraft 启动器" Style="{StaticResource CaptionStyle}" TextAlignment="Center"/>
                </StackPanel>

                <!-- Login Form -->
                <controls:Card>
                    <StackPanel Spacing="16">
                        <!-- Username -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="用户名" Style="{StaticResource BodyStyle}"/>
                            <controls:MyTextBox Placeholder="请输入用户名"
                                               Text="{Binding Username, Mode=TwoWay}"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="密码" Style="{StaticResource BodyStyle}"/>
                            <controls:MyTextBox Placeholder="请输入密码"
                                               Text="{Binding Password, Mode=TwoWay}"
                                               IsPassword="True"/>
                        </StackPanel>

                        <!-- Options -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <controls:MyCheckBox Grid.Column="0"
                                               Label="记住密码"
                                               IsChecked="{Binding RememberMe}"/>

                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButtonStyle}"
                                    Click="OnOfflineModeClick">
                                <TextBlock Text="🌐" ToolTipService.ToolTip="{Binding IsOfflineMode, Converter={StaticResource BoolToOfflineText}}"/>
                            </Button>
                        </Grid>

                        <!-- Status -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource CaptionStyle}"
                                   TextAlignment="Center"/>

                        <!-- Login Button -->
                        <controls:MyButton Text="登录"
                                         Command="{Binding LoginCommand}"
                                         IsEnabled="{Binding CanLogin}"
                                         HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </controls:Card>

                <!-- Other Login Options -->
                <controls:Card>
                    <StackPanel Spacing="12">
                        <TextBlock Text="其他登录方式" Style="{StaticResource TitleStyle}" TextAlignment="Center"/>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource BaseButtonStyle}" Background="{StaticResource BackgroundTertiaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="📱" FontSize="16"/>
                                    <TextBlock Text="第三方登录"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Style="{StaticResource BaseButtonStyle}" Background="{StaticResource BackgroundTertiaryBrush}">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🔑" FontSize="16"/>
                                    <TextBlock Text="离线模式"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </controls:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
