<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <AssemblyTitle>PCL-CE.Neo.UI</AssemblyTitle>
    <AssemblyName>PCL-CE.Neo.UI</AssemblyName>
    <Description>PCL CE Neo Uno Platform UI</Description>
    <Company>PCL Community</Company>
    <Product>PCL-CE.Neo.UI</Product>
    <Copyright>Copyright © PCL Community</Copyright>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    
    <TargetFramework>net10.0-desktop</TargetFramework>
    
    <UnoFeatures>SkiaRenderer;Extensions;Toolkit;Material</UnoFeatures>
    
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PCL_CE.Neo.UI</RootNamespace>
    
    <!-- 禁用默认RuntimeIdentifier避免产生不支持的RID -->
    <EnableDefaultRuntimeIdentifier>false</EnableDefaultRuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../PCL-CE.Neo.Core.Abstractions/PCL-CE.Neo.Core.Abstractions.csproj" />
    <ProjectReference Include="../PCL-CE.Neo.Core/PCL-CE.Neo.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Remove="Resources/**" />
    <Content Include="Resources/**" />
  </ItemGroup>

  <ItemGroup>
    <Page Include="**/*.xaml" Exclude="bin/**/*.xaml;obj/**/*.xaml" />
  </ItemGroup>
</Project>
