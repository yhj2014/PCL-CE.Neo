<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyTitle>PCL-CE.Neo.UI</AssemblyTitle>
    <AssemblyName>PCL-CE.Neo.UI</AssemblyName>
    <Description>PCL CE Neo UI Library</Description>
    <Company>PCL Community</Company>
    <Product>PCL-CE.Neo.UI</Product>
    <Copyright>Copyright © PCL Community</Copyright>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    
    <TargetFramework>net10.0</TargetFramework>
    
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PCL_CE.Neo.UI</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../PCL-CE.Neo.Core.Abstractions/PCL-CE.Neo.Core.Abstractions.csproj" />
    <ProjectReference Include="../PCL-CE.Neo.Core/PCL-CE.Neo.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- 暂时排除 XAML 和 UI 相关文件，先让核心代码编译通过 -->
    <Compile Remove="Controls/**/*.cs" />
    <Compile Remove="Pages/**/*.cs" />
    <Compile Remove="Navigation/*.cs" />
    <Compile Remove="Themes/*.cs" />
    <Compile Remove="ViewModels/**/*.cs" />
    <Compile Remove="Animations/**/*.cs" />
    <Compile Remove="Services/AudioService.cs" />
    <Compile Remove="Services/WindowService.cs" />
    <Compile Remove="App.xaml.cs" />
    <Compile Remove="MainWindow.xaml.cs" />
  </ItemGroup>
</Project>
