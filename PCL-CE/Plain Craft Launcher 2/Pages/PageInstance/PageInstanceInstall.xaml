                                       x:Name="HintFabricAPI" IsWarn="True" />
                        <local:MyHint
                            Text="{DynamicResource Download.Install.Warning.Qsl}"
                            Margin="0,1,0,7" x:Name="HintQSL" IsWarn="True" />
                        <local:MyHint Text="{DynamicResource Download.Install.Warning.QuiltFabricApi}"
